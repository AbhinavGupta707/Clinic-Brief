DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/clinicbrief"
CLINICBRIEF_DATA_BACKEND="memory"
# memory is the default; use supabase only with the three private storage env vars below.
CLINICBRIEF_STORAGE_BACKEND="memory"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="clinicbrief"
FIREWORKS_API_KEY=""
FIREWORKS_MODEL="accounts/fireworks/models/deepseek-v3p1"
# Set true in production when guided onboarding must use Fireworks instead of deterministic fallback.
CLINICBRIEF_REQUIRE_AI="false"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Server-side Track API integration key from the Novus/Pendo generated PR. Keep server-only.
PENDO_INTEGRATION_KEY=""
# Optional public dashboard-generated key used by the NovusPendoProvider browser SDK path.
NEXT_PUBLIC_NOVUS_CLIENT_KEY=""
NEXT_PUBLIC_PENDO_API_KEY=""
NOVUS_API_KEY=""
