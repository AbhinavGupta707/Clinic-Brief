{
  "name": "clinicbrief",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "postinstall": "pnpm --filter @clinicbrief/db db:generate",
    "dev": "pnpm --filter @clinicbrief/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @clinicbrief/db db:generate",
    "db:validate": "pnpm --filter @clinicbrief/db db:validate",
    "db:push": "pnpm --filter @clinicbrief/db db:push",
    "db:migrate": "pnpm --filter @clinicbrief/db db:migrate",
    "smoke:memory": "node scripts/smoke-check.mjs memory",
    "smoke:ai": "node scripts/smoke-check.mjs ai",
    "smoke:db": "node scripts/smoke-check.mjs db",
    "smoke:storage": "node scripts/smoke-check.mjs storage",
    "smoke:full": "node scripts/smoke-check.mjs full",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
