{
  "name": "@clinicbrief/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm db:validate && tsc --noEmit",
    "lint": "pnpm db:validate && tsc --noEmit",
    "typecheck": "pnpm db:validate && tsc --noEmit",
    "test": "pnpm db:validate",
    "db:generate": "node ../../scripts/prisma-cli.mjs generate",
    "db:validate": "node ../../scripts/prisma-cli.mjs validate",
    "db:push": "node ../../scripts/prisma-cli.mjs push",
    "db:migrate": "node ../../scripts/prisma-cli.mjs migrate",
    "smoke:live": "pnpm db:generate && node scripts/smoke-prisma.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "prisma": "^6.1.0"
  }
}
