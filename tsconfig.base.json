{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@clinicbrief/types": ["packages/types/src/index.ts"],
      "@clinicbrief/ai": ["packages/ai/src/index.ts"],
      "@clinicbrief/events": ["packages/events/src/index.ts"],
      "@clinicbrief/documents": ["packages/documents/src/index.ts"],
      "@clinicbrief/exports": ["packages/exports/src/index.ts"],
      "@clinicbrief/fixtures": ["packages/fixtures/src/index.ts"]
    }
  }
}
